# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx

# Resend (Email)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_ADDRESS=The Leadership Federation <events@theleadershipfederation.com>

# Who gets the "new contact inquiry" email from the public /contact form.
# Change this in Vercel env to redirect without a code deploy.
CONTACT_NOTIFY_EMAIL=owner@example.com

# First-time setup allow-list: comma-separated emails that may bootstrap
# themselves into the admin console as super_admin IF team_members is
# empty. After the first successful login the row is auto-created and
# this env has no further effect — additional team members must be
# added via the admin Settings → Profiles & Access flow. Keep this
# narrow (ideally one email) and remove from Vercel env once the first
# admin has logged in.
ADMIN_BOOTSTRAP_EMAIL=sunnymshah@gmail.com

# Site URL (used for email link-backs). Defaults to the Vercel
# production URL if unset.
NEXT_PUBLIC_SITE_URL=https://theleadershipfederation.vercel.app
